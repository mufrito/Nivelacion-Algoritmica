Algoritmo nombre
	//Escribe un algoritmo que permita conocer el area de un triangulo a partir de la base y
	//altura
	Definir b,a,Operacion,division Como Real
	Escribir "Ingresa la altura"
	leer a
	Escribir "Ingresa la base"
	Leer b
	Operacion <- (b*a)
	division <- (Operacion/2)
	Escribir "El area del triangulo es " division

FinAlgoritmo